<ScrollPane hbarPolicy="NEVER" pannable="true" prefHeight="700.0" prefWidth="500.0" vbarPolicy="ALWAYS" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.ThongTinDoanhNghiep_Controller">
   <content>
      <AnchorPane prefHeight="700.0" prefWidth="500.0">
         <children>
            <StackPane layoutX="-2.0" layoutY="1.0" prefHeight="242.0" prefWidth="500.0">
               <children>
                  <ImageView fitHeight="311.0" fitWidth="510.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@images/anh4.jpg" />
                     </image>
                  </ImageView>
                  <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#26282959" height="250.0" stroke="BLACK" strokeType="INSIDE" width="510.0" />
                  <Label alignment="TOP_LEFT" contentDisplay="CENTER" prefHeight="65.0" prefWidth="295.0" text="   THÔNG TIN VỀ CHÚNG TÔI" textFill="#fffcfc" StackPane.alignment="BOTTOM_LEFT">
                     <font>
                        <Font size="22.0" />
                     </font>
                     <effect>
                        <DropShadow spread="0.3" />
                     </effect>
                  </Label>
                  <Button fx:id="btnBack" mnemonicParsing="false" onAction="#veTrangChu" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="←" textFill="#000000fe" StackPane.alignment="TOP_LEFT">
