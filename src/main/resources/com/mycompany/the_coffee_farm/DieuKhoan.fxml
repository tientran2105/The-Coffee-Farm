<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="700.0" prefWidth="500.0" style="-fx-background-color: #FFFDE7;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.the_coffee_farm.DieuKhoan_Controller">
    <children>
        <Label prefHeight="60.0" prefWidth="500.0" />
        <Button layoutX="14.0" layoutY="4.0" mnemonicParsing="false" onAction="#quayLaiAccount" prefHeight="20.0" prefWidth="62.0" style="-fx-background-color: transparent;" text="←">
            <font>
                <Font size="23.0" />
            </font>
        </Button>
        <Label layoutX="155.0" layoutY="14.0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;" text="Điều khoản sử dụng">
            <font>
                <Font size="9.0" />
            </font>
        </Label>
        <ScrollPane fitToWidth="true" layoutY="54.0" prefHeight="646.0" prefWidth="500.0">
            <content>
                <VBox prefHeight="640.0" prefWidth="485.0" spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Giới Thiệu">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Khi khách hàng truy cập vào ứng dụng The Coffee Farm hoặc đặt hàng qua hotline xxxxxxxxxxx của The Coffee Farm có nghĩa là khách hàng đã đồng ý với các điều khoản này. The Coffee Farm có quyền thay đổi, chỉnh sửa, thêm hoặc lược bỏ bất kỳ phần nào trong Điều khoản sử dụng này vào bất cứ lúc nào. Các thay đổi có hiệu lực ngay khi được đăng trên trang web, ứng dụng mà không cần thông báo trước. Khi khách hàng tiếp tục sử dụng dịch vụ giao hàng của The Coffee Farm, sau khi các thay đổi về Điều khoản này được đăng tải, có nghĩa là khách hàng chấp nhận với những thay đổi đó.Khách hàng vui lòng kiểm tra thường xuyên để cập nhật những thay đổi của chúng tôi." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Giới thiệu về các loại dịch vụ">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Dịch vụ &quot;Giao hàng&quot;: là dịch vụ mà khách hàng đặt sản phẩm ngay tại nhà và được The Coffee Farm giao hàng tận nơi." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Sau khi khách hàng đặt hàng thành công, The Coffee Farm sẽ thực hiện đơn hàng và giao hàng đến địa chỉ mà khách hàng đã chọn." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Dịch vụ &quot;Mang đi&quot; (tại ứng dụng The Coffee Farm): là dịch vụ mà khách hàng có thể đặt món trước và đến The Coffee Farm nhận sản phẩm mang đi." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Sau khi chọn hình thức &quot;Mang Đi&quot; và đặt hàng thành công, khách hàng chủ động đến Cửa hàng đã chọn trên đơn hàng để nhận sản phẩm." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Chính sách sử dụng dịch vụ">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Khách hàng được quyền chủ động chọn loại dịch vụ để sử dụng khi bắt đầu đặt đơn hàng. Với đơn hàng của dịch vụ &quot;Giao hàng&quot; và &quot;Mang đi&quot;, khách hàng vui lòng không sử dụng tại Cửa hàng. The Coffee Farm có quyền từ chối hỗ trợ giao hàng với đơn hàng của dịch vụ &quot;Mang đi&quot;." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Chấp nhận đơn hàng và giá cả">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="The Coffee Farm có quyền từ chối hoặc hủy đơn hàng của khách hàng vì bất kỳ lý do gì liên quan đến lỗi kỹ thuật, hệ thống một cách khách quan sau khi đã liên hệ thông báo với khách hàng. Trường hợp liên hệ 3 lần liên tục không thành công trong vòng 30 phút, chúng tôi sẽ tự động hủy đơn hàng của quý khách. The Coffee Farm rất tiếc vì chưa thể hoàn thành đơn hàng của quý khách trong trường hợp này." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="The Coffee Farm cam kết sẽ cung cấp thông tin giá cả chính xác nhất cho khách hàng. Tuy nhiên, đôi lúc vẫn có sai sót xảy ra, ví dụ như trường hợp giá sản phẩm không hiển thị chính xác trên trang web hoặc sai giá, tùy theo từng trường hợp chúng tôi sẽ liên hệ hướng dẫn hoặc thông báo hủy đơn hàng đó cho khách hàng." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Thay đổi thông tin đặt hàng">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Khách hàng vui lòng cung cấp thông tin đầy đủ và chính xác ngay khi hoàn tất đặt hàng tại The Coffee Farm." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="The Coffee Farm chỉ chấp nhận thay đổi thông tin trên đơn hàng bao gồm: địa chỉ giao hàng, sản phẩm trong giỏ hàng, thông tin người nhận, thời gian giao nhận trước bước Thực hiện đơn hàng trên ứng dụng. Tùy thuộc từng trường hợp có thể hỗ trợ khách hàng sau khi kiểm tra với cửa hàng thực hiện đơn hàng và đơn vị vận chuyển, The Coffee Farm sẽ liên hệ thông tin cho khách hàng hoặc có quyền từ chối hỗ trợ." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Hủy bỏ đặt hàng">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Khách hàng được quyền chủ động hủy đơn hàng trên ứng dụng đối với trường hợp đơn hàng chưa có tài xế nhận giao hàng." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Khách hàng vui lòng liên hệ hotline 18006936 để hủy đơn hàng với các trường hợp: Đơn hàng đã có tài xế nhận giao hàng (từ bước Đã tìm thấy tài xế trên ứng dụng)." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Đơn hàng sẽ được trả về cửa hàng nếu nhân viên giao hàng không liên lạc được với Khách hàng tại thời điểm giao hàng (tối đa 3 cuộc gọi)." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Với trường hợp Đã giao đơn hàng đến địa chỉ yêu cầu, tuy nhiên không liên hệ được người nhận trong vòng 30 phút kể từ tài xế trả hàng về cửa hàng:" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Đơn thanh toán COD: Đơn hàng sẽ được hủy và hủy bỏ việc tích điểm cho đơn hàng này." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Đơn đã thanh toán Online: Không hoàn tiền, The Coffee Farm sẽ lưu giữ đơn hàng và chỉ hỗ trợ giao lại đơn hàng trong ngày cho khách hàng (The Coffee Farm chưa thể đảm bảo về chất lượng sản phẩm nếu thời gian giao hàng hơn 30 phút)." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="The Coffee Farm sẽ có toàn quyền không thực hiện đặt hàng của khách hàng trong các trường hợp sau:" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Địa chỉ được chọn nằm ngoài khu vực giao hàng được cung cấp trên ứng dụng" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Không liên lạc được với khách hàng qua điện thoại vào thời điểm xác nhận đặt hàng" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Không thực hiện được đơn hàng của khách hàng do thiếu thông tin, chỉ dẫn hoặc ủy quyền từ khách hàng tại thời điểm giao hàng" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Không có sẵn tất cả các mặt hàng khách hàng đặt mua tại thời điểm đặt hàng" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Phương thức thanh toán">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="      + Thanh toán tiền mặt (COD): thanh toán khi giao hàng" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Thanh toán trực tuyến bằng thẻ nội địa (ATM), thẻ quốc tế (Visa, Master...) qua cổng thanh toán" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Thanh toán trực tuyến bằng các ví điện tử như Momo, ZaloPay, ShopeePay..." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Chính sách tài khoản người dùng" wrapText="true">
                            <font>
                                <Font name="Arial Bold" size="20.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Mỗi số điện thoại chỉ tạo được một (01) tài khoản cho mục đích sử dụng cá nhân." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Để đảm bảo quyền lợi, khách hàng không chia sẻ thông tin tài khoản (tên truy cập và mật khẩu) cho người khác sử dụng tài khoản The Coffee Farm, hoặc chuyển nhượng tài khoản cho bất kỳ ai khác mà chưa thông qua The Coffee Farm." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="The Coffee Farm có quyền khóa tài khoản hoặc khóa một phần tính năng của tài khoản (như tính năng Đặt hàng/Tích điểm..) của khách hàng khi The Coffee Farm phát hiện khách hàng vi phạm điều khoản hoặc chính sách của công ty hoặc có hành vi mua hàng không trung thực điển hình như:" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Tạo các đơn hàng ảo, boom hàng hoặc đánh giá ảo" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Có dấu hiệu lừa đảo hoặc lạm dụng các mã giảm giá và chương trình khuyến mãi để trục lợi" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="      + Các trường hợp khác mà hệ thống của The Coffee Farm phát hiện được. Tùy từng trường hợp, The Coffee Farm sẽ có biện pháp xử lý thích hợp, bao gồm khóa tài khoản mà không cần thông báo trước" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" text="Tài khoản bị khóa hoặc khóa một phần tính năng sẽ được cấp lại sau khi hoàn thành quá trình xác minh qua các chứng từ/thông tin khách hàng cung cấp chứng minh việc mua hàng (hóa đơn, hình ảnh sản phẩm đã mua,..) và có sự đồng thuận giữa khách hàng và The Coffee Farm." wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
